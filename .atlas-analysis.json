  "keyFeatures": [
    "Lightweight Result type with Ok/Err discriminated union",
    "Generator-based composition with yield* syntax",
    "TaggedError factory for exhaustive error matching",
    "Built-in retry logic with exponential backoff",
    "Serialization support for RPC and server actions",
    "Panic type for unrecoverable errors",
    "Dual API (data-first and data-last/pipeable)",
    "Full TypeScript type safety with phantom types"
  ],
  "publicApiSurface": [
    "Result.ok(value)",
    "Result.err(error)",
    "Result.try(fn)",
    "Result.tryPromise(fn, config?)",
    "Result.gen(generator)",
    "Result.await(promise)",
    "Result.map(result, fn)",
    "Result.mapError(result, fn)",
    "Result.andThen(result, fn)",
    "Result.match(result, handlers)",
    "Result.serialize(result)",
